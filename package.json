{
  "name": "@zhenghy/doc-preview",
  "version": "0.3.1",
  "description": "A Vue 3 component for previewing .doc files in browser",
  "type": "module",
  "main": "./dist/doc-preview.umd.cjs",
  "module": "./dist/doc-preview.js",
  "exports": {
    ".": {
      "import": "./dist/doc-preview.js",
      "require": "./dist/doc-preview.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:lib": "vue-tsc && vite build --mode lib",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "vue3",
    "vue",
    "doc",
    "preview",
    "word",
    "ole2",
    "cfb",
    "document",
    "parser"
  ],
  "author": "zhenghy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhenghy-gh/doc-preview.git"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9",
    "vue": "^3.4.21",
    "vue-tsc": "^3.3.5"
  }
}
